# ── Private folders: folder is tracked, contents are NOT ──────────────────────
# To add more private folders, follow this pattern:
#   <folder_name>/*
#   !<folder_name>/.gitkeep
17_Bug_Bounty/*
!17_Bug_Bounty/.gitkeep
